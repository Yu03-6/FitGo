<view class="page booking-page" wx:if="{{companion}}">
  <view class="booking-hero card">
    <view class="avatar" style="background: linear-gradient(135deg, {{companion.color}}, {{companion.colorAccent}});">
      <text>{{companion.avatar}}</text>
      <view class="status {{companion.online ? 'online' : ''}}"></view>
    </view>
    <view class="booking-companion">
      <view class="booking-name">预约 {{companion.name}}</view>
      <view class="booking-role">{{companion.role}}</view>
      <view class="booking-rating">★ {{companion.rating}} · ¥{{companion.price}} / 小时</view>
    </view>
  </view>

  <view class="form-block">
    <view class="form-title">选择服务</view>
    <view
      class="package-option {{selectedPackageId == item.id ? 'active' : ''}}"
      wx:for="{{servicePackages}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="selectPackage"
    >
      <view class="package-icon" style="color: {{item.color}};">{{item.icon}}</view>
      <view class="package-copy">
        <view class="package-name">{{item.title}}</view>
        <view class="package-desc">{{item.description}}</view>
      </view>
      <view class="check" wx:if="{{selectedPackageId == item.id}}">✓</view>
    </view>
  </view>

  <view class="form-block">
    <view class="form-title">时长</view>
    <view class="duration-row">
      <view
        class="duration-chip {{durationHours == item ? 'active' : ''}}"
        wx:for="{{durationOptions}}"
        wx:key="*this"
        data-hour="{{item}}"
        bindtap="selectDuration"
      >
        {{item}} 小时
      </view>
    </view>
  </view>

  <view class="form-block">
    <view class="form-title">开黑时间</view>
    <picker mode="selector" range="{{timeSlots}}" value="{{timeIndex}}" bindchange="changeTime">
      <view class="picker-card">{{timeSlots[timeIndex]}}</view>
    </picker>
  </view>

  <view class="form-block">
    <view class="form-title">语音方式</view>
    <picker mode="selector" range="{{voiceChannels}}" value="{{voiceIndex}}" bindchange="changeVoice">
      <view class="picker-card">{{voiceChannels[voiceIndex]}}</view>
    </picker>
  </view>

  <view class="form-block">
    <view class="form-title">补充需求</view>
    <textarea
      class="note-input"
      maxlength="120"
      placeholder="例如：想练航天基地摸金路线，需要温柔指挥"
      bindinput="inputNote"
    />
  </view>

  <view class="submit-bar card">
    <view>
      <view class="muted">合计</view>
      <view class="total">¥{{totalPrice}}</view>
    </view>
    <button class="primary-button submit-button" bindtap="submitOrder">提交预约</button>
  </view>
</view>
